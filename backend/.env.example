# App Config
APP_NAME="Codebase Intelligence"
DEBUG=False
API_V1_PREFIX="/api/v1"

# Database Config
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codebase_intel

# GitHub Config
GITHUB_TOKEN=your_github_token_here

# Storage Config
STORAGE_BACKEND=local
REPOS_BASE_DIR=./repos

# AWS Storage Config (Required if STORAGE_BACKEND is "s3")
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
AWS_S3_BUCKET=codebase-intel-artifacts

# File Filtering Config
MAX_FILE_SIZE_KB=500
BINARY_CHECK_BYTES=8000

# Chunking Config
DEFAULT_CHUNK_SIZE=1500
DEFAULT_CHUNK_OVERLAP=200

# ChromaDB Config
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_PREFIX=repo_

# Embeddings Config
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

# LLM Config
LLM_PROVIDER=gemini
LLM_MODEL=gemini-pro
GEMINI_API_KEY=your_gemini_api_key_here

